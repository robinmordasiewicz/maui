---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Kanaha Wind Report', description = 'Daily watersport forecasts for Kanaha Beach Park, Maui' } = Astro.props;
const siteTitle = 'Kanaha Wind Report';
---

<!doctype html>
<html lang="en" class="bg-ocean-950 text-gray-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/maui/favicon.svg" />
    <title>{title} | {siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-ocean-800 bg-ocean-900/80 backdrop-blur sticky top-0 z-10">
      <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/maui/" class="flex items-center gap-2 text-xl font-bold text-ocean-300 hover:text-ocean-200 transition">
          <span class="text-2xl">🏖️</span>
          <span>Kanaha Wind Report</span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/maui/docs/" class="text-sm text-ocean-400 hover:text-ocean-300 transition">Docs</a>
          <span class="text-sm text-ocean-500">Maui, HI</span>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-3xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <footer class="border-t border-ocean-800 text-ocean-500 text-sm">
      <div class="max-w-3xl mx-auto px-4 py-6 text-center">
        Automated forecasts from live sensor data · <a href="https://github.com/robinmordasiewicz/maui" class="text-ocean-400 hover:text-ocean-300">Source</a>
      </div>
    </footer>
  </body>
</html>
