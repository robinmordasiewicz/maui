---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base>
  <div class="space-y-4">
    {posts.length === 0 && (
      <p class="text-ocean-400 text-center py-12">No forecasts yet. Check back soon.</p>
    )}
    {posts.map((post) => {
      const isPreview = post.data.title.includes('Preview');
      const dateStr = post.data.pubDate.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        timeZone: 'Pacific/Honolulu',
      });
      const timeStr = post.data.pubDate.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        timeZone: 'Pacific/Honolulu',
      });
      return (
        <a href={`/maui/blog/${post.id}/`}
          class="block bg-ocean-900/50 border border-ocean-800 rounded-lg p-5 hover:border-ocean-600 hover:bg-ocean-900/80 transition group">
          <div class="flex items-center gap-2 mb-2">
            {isPreview ? (
              <span class="text-xs font-semibold text-amber-300 bg-amber-500/20 px-2 py-0.5 rounded">PREVIEW</span>
            ) : (
              <span class="text-xs font-semibold text-emerald-300 bg-emerald-500/20 px-2 py-0.5 rounded">LIVE</span>
            )}
            <span class="text-ocean-400 text-sm">{dateStr} · {timeStr} HST</span>
          </div>
          <h2 class="text-lg font-semibold text-white group-hover:text-ocean-200 transition">{post.data.title}</h2>
          <p class="text-sm text-ocean-400 mt-1">{post.data.description}</p>
        </a>
      );
    })}
  </div>
</Base>
