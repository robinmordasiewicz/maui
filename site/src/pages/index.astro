---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base>
  <div class="space-y-4">
    {posts.length === 0 && (
      <p class="text-gray-500 dark:text-gray-500 text-center py-16">No forecasts yet. Check back soon.</p>
    )}
    {posts.map((post) => {
      const isPreview = post.data.title.includes('Preview');
      const dateStr = post.data.pubDate.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        timeZone: 'Pacific/Honolulu',
      });
      const timeStr = post.data.pubDate.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        timeZone: 'Pacific/Honolulu',
      });
      return (
        <a href={`/maui/blog/${post.id}/`}
          class="block bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5 shadow-card hover:shadow-card-hover dark:shadow-card-dark hover:border-brand-300 dark:hover:border-brand-700 transition-all duration-200 group">
          <div class="flex items-center gap-2 mb-2">
            {isPreview ? (
              <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/30 px-2 py-0.5 rounded-full">PREVIEW</span>
            ) : (
              <span class="text-xs font-semibold text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/30 px-2 py-0.5 rounded-full">LIVE</span>
            )}
            <span class="text-gray-500 dark:text-gray-500 text-sm">{dateStr} · {timeStr} HST</span>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition">{post.data.title}</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-2">{post.data.description}</p>
        </a>
      );
    })}
  </div>
</Base>
